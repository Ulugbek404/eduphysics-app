rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper funksiyalar ──────────────────────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isAdmin() {
      return isLoggedIn() && getUserRole() == "admin";
    }

    function isTeacher() {
      return isLoggedIn() && getUserRole() == "teacher";
    }

    function isAdminOrTeacher() {
      return isAdmin() || isTeacher();
    }

    // Matn uzunligi va xavfsizlik tekshiruvi
    function isValidText(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    // Foydalanuvchi profili validatsiyasi (UPDATE uchun)
    // Muhim: request.resource.data — hujjatning YAKUNIY holati, shuning uchun
    // "'role' in data" tekshiruvi ishlamaydi; o'zgargan maydonlarni diff() bilan aniqlaymiz
    function isValidUserUpdate() {
      let data = request.resource.data;
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return (
        // himoyalangan maydonlarni foydalanuvchi o'zi o'zgartira olmaydi
        !changed.hasAny(['role', 'uid', 'email', 'blocked']) &&
        (!('displayName' in data) || isValidText(data.displayName, 100)) &&
        (!('bio' in data)         || isValidText(data.bio, 300)) &&
        (!('school' in data)      || isValidText(data.school, 150)) &&
        (!('phone' in data)       || isValidText(data.phone, 20)) &&
        (!('learnedFormulas' in data) || data.learnedFormulas is list) // formula o'rganish
      );
    }

    // Yangi profil yaratish validatsiyasi (CREATE uchun — role 'student' bo'lishi shart)
    function isValidUserCreate() {
      let data = request.resource.data;
      return (
        data.uid == request.auth.uid &&
        (!('role' in data) || data.role == 'student') &&
        (!('displayName' in data) || isValidText(data.displayName, 100))
      );
    }

    // ─── USERS ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isLoggedIn() && (isOwner(userId) || isAdminOrTeacher());
      // Yangi hujjat yaratishda (ro'yxatdan o'tish / sinxronizatsiya):
      // faqat o'z UID i bo'lishi va role='student' bo'lishi shart
      allow create: if isLoggedIn() && isOwner(userId) && isValidUserCreate();
      // Foydalanuvchi o'zini yangilay oladi, LEKIN role ni emas!
      allow update: if isLoggedIn() && (
        (isOwner(userId) && isValidUserUpdate()) ||
        (isAdmin())
      );
      allow delete: if isLoggedIn() && isAdmin();
      allow list:   if isLoggedIn() && isAdminOrTeacher();
    }

    // ─── ANNOUNCEMENTS ───────────────────────────────────────────────────────
    match /announcements/{announcementId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn() && isAdmin();
      allow update: if isLoggedIn() && isAdmin();
      allow delete: if isLoggedIn() && isAdmin();
    }

    // ─── CONFIG (Admin sozlamalari) ──────────────────────────────────────────
    match /config/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isLoggedIn() && isAdmin();
    }

    // ─── MISSIONS ────────────────────────────────────────────────────────────
    match /missions/{userId} {
      allow read:  if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow write: if isLoggedIn() && (isOwner(userId) || isAdmin());
    }

    // ─── XP LOGS — faqat yaratish, o'zgartirish/o'chirish mumkin emas ────────
    match /xpLogs/{userId}/logs/{logId} {
      allow read:          if isLoggedIn() && (isOwner(userId) || isAdminOrTeacher());
      allow create:        if isLoggedIn() && isOwner(userId);
      allow update, delete: if false; // XP loglari o'zgartirilmaydi — muhim!
    }

    // ─── LEADERBOARD ─────────────────────────────────────────────────────────
    match /leaderboard/{document=**} {
      allow read:  if isLoggedIn();
      allow write: if isLoggedIn() && (
        (request.resource.data.uid == request.auth.uid) || isAdmin()
      );
    }

    // ─── ASSIGNMENTS ─────────────────────────────────────────────────────────
    match /assignments/{assignmentId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn() && isAdminOrTeacher();
      allow update: if isLoggedIn() && isAdminOrTeacher();
      allow delete: if isLoggedIn() && isAdminOrTeacher();
    }

    // ─── NOTIFICATIONS ───────────────────────────────────────────────────────
    match /notifications/{userId}/messages/{messageId} {
      allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow create: if isLoggedIn() && isAdminOrTeacher();
      allow update: if isLoggedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isLoggedIn() && isAdmin();
    }

    // ─── PROGRESS ────────────────────────────────────────────────────────────
    match /progress/{userId} {
      allow read:  if isLoggedIn() && (isOwner(userId) || isAdminOrTeacher());
      allow write: if isLoggedIn() && (isOwner(userId) || isAdmin());
    }

    // ─── ROOMS (Live Test) ────────────────────────────────────────────────────
    match /rooms/{roomCode} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn() && isAdmin();
      // Admin (host) hamma maydonni, oddiy o'quvchi faqat answeredCount ni yangilaydi
      allow update: if isLoggedIn() && (
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['answeredCount'])
      );
      allow delete: if isLoggedIn() && isAdmin();

      match /players/{uid} {
        allow read:   if isLoggedIn();
        allow create: if isLoggedIn() && isOwner(uid);
        allow update: if isLoggedIn() && isOwner(uid);
        allow delete: if isLoggedIn() && isAdmin();
      }

      match /answers/{answerId} {
        allow read:   if isLoggedIn();
        allow create: if isLoggedIn();
        allow update: if false; // Javoblar o'zgartirilmaydi!
        allow delete: if false;
      }
    }

    // ─── CONTACTS — spam himoyasi ─────────────────────────────────────────────
    match /contacts/{docId} {
      // Tashqaridan ham yuborish mumkin (login talab qilinmaydi)
      // LEKIN: validatsiya kerak
      allow create: if (
        request.resource.data.keys().hasOnly(['name', 'email', 'subject', 'message', 'createdAt', 'read']) &&
        request.resource.data.keys().hasAll(['name', 'message']) &&
        isValidText(request.resource.data.name, 100) &&
        isValidText(request.resource.data.message, 1000) &&
        (!('email' in request.resource.data)   || isValidText(request.resource.data.email, 150)) &&
        (!('subject' in request.resource.data) || isValidText(request.resource.data.subject, 200)) &&
        (!('read' in request.resource.data)    || request.resource.data.read == false)
      );
      allow read, update, delete: if isAdmin();
    }

    // ─── HOMEWORK SUBMISSIONS ─────────────────────────────────────────────────
    match /homeworkSubmissions/{docId} {
      // O'quvchi faqat o'z topshiriqlarini ko'radi va yuboradi
      allow create: if isLoggedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read:   if isLoggedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdminOrTeacher()
      );
      // O'qituvchi baho qo'yishi uchun update ruxsati
      allow update: if isLoggedIn() && isAdminOrTeacher();
      allow delete: if isLoggedIn() && isAdmin();
    }

  }
}
