# ─── Firebase (web config — ochiq bo'lishi normal, himoya firestore.rules da) ───
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Gemini AI ───────────────────────────────────────────────────────────────
# DIQQAT: VITE_ prefiksli kalitlar build paytida CLIENT BUNDLE ichiga kiradi
# va saytga kirgan har kim ularni ko'ra oladi! Imkon qadar Gemini so'rovlarini
# netlify/functions orqali yuboring (u yerda GEMINI_API_KEY_1/2 server-side).
VITE_GEMINI_API_KEY=
VITE_GEMINI_API_KEY_1=
VITE_GEMINI_API_KEY_2=

# Netlify server-side kalitlar (Netlify dashboard > Environment variables ga qo'ying,
# bu faylga yozish shart emas):
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=

# ─── Admin ro'yxatdan o'tish kodi ────────────────────────────────────────────
# Bo'sh qoldirilsa admin sifatida ro'yxatdan o'tish o'chiq bo'ladi.
# Eslatma: bu ham bundle da ko'rinadi — haqiqiy himoya firestore.rules da
# (yangi user faqat role='student' bilan yaratiladi).
VITE_ADMIN_SIGNUP_CODE=
